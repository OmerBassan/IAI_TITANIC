# Kaggle credentials — copy this file to .env and fill in your values.
# Get them from https://www.kaggle.com/settings (Account > API > Create New Token)
#
# Option A: username + API key (from kaggle.json)
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# Option B: paste the full token string from kaggle.json as a single env var
# KAGGLE_API_TOKEN={"username":"...","key":"..."}
